{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BatchMkvMerge",
  "version": "0.2.0",
  "identifier": "com.caoccao.batch-mkvmerge",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "batch-mkvmerge",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "languages": [
          "English",
          "German",
          "Spanish",
          "French",
          "Italian",
          "Japanese",
          "SimpChinese",
          "TradChinese"
        ]
      },
      "wix": {
        "language": [
          "en-US",
          "de-DE",
          "es-ES",
          "fr-FR",
          "it-IT",
          "ja-JP",
          "zh-CN",
          "zh-TW"
        ]
      }
    }
  }
}
